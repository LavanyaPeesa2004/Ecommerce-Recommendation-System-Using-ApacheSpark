{
  "datasets": [
    {
      "name": "9ad42bcc",
      "displayName": "TOP10",
      "queryLines": [
        "SELECT\r\n",
        "    product_name,\r\n",
        "    purchases\r\n",
        "FROM top_trending_products\r\n",
        "ORDER BY purchases DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "5be6cc2a",
      "displayName": "Database Tables Overview Snapshot",
      "queryLines": [
        "SHOW TABLES"
      ]
    },
    {
      "name": "378b6323",
      "displayName": "Top 5 Recommended Products (ALS)",
      "queryLines": [
        "SELECT\r\n",
        "    product_name,\r\n",
        "    prediction\r\n",
        "FROM recommended_products\r\n",
        "ORDER BY prediction DESC;"
      ]
    },
    {
      "name": "8c238eb3",
      "displayName": "Department Purchase Counts Summary Report",
      "queryLines": [
        "SELECT\r\n",
        "    department,\r\n",
        "    COUNT(*) AS total_purchases\r\n",
        "FROM silver_customer_products\r\n",
        "GROUP BY department\r\n",
        "ORDER BY total_purchases DESC;"
      ]
    },
    {
      "name": "81e30c69",
      "displayName": "Weekly Order Distribution Summary",
      "queryLines": [
        "SELECT\r\n",
        "    CASE order_dow\r\n",
        "        WHEN 0 THEN 'Sunday'\r\n",
        "        WHEN 1 THEN 'Monday'\r\n",
        "        WHEN 2 THEN 'Tuesday'\r\n",
        "        WHEN 3 THEN 'Wednesday'\r\n",
        "        WHEN 4 THEN 'Thursday'\r\n",
        "        WHEN 5 THEN 'Friday'\r\n",
        "        WHEN 6 THEN 'Saturday'\r\n",
        "    END AS day_of_week,\r\n",
        "    COUNT(*) AS total_orders\r\n",
        "FROM silver_customer_products\r\n",
        "GROUP BY order_dow\r\n",
        "ORDER BY order_dow;"
      ]
    },
    {
      "name": "fbb06273",
      "displayName": "Customer Purchase Counts by Hour of Day",
      "queryLines": [
        "SELECT\r\n",
        "    order_hour_of_day,\r\n",
        "    COUNT(*) AS total_orders\r\n",
        "FROM silver_customer_products\r\n",
        "GROUP BY order_hour_of_day\r\n",
        "ORDER BY order_hour_of_day;"
      ]
    },
    {
      "name": "bd58f4d1",
      "displayName": "Unique Customer Count Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT user_id) AS total_customers\r\n",
        "FROM silver_customer_products;"
      ]
    },
    {
      "name": "2ec45dda",
      "displayName": "Unique Product Count Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT product_id) AS total_products\r\n",
        "FROM silver_customer_products;"
      ]
    },
    {
      "name": "8ad06040",
      "displayName": "Unique Order Count Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT order_id) AS total_orders\r\n",
        "FROM silver_customer_products;"
      ]
    },
    {
      "name": "c1c45292",
      "displayName": "Distinct Department Count in Customer Products Dataset",
      "queryLines": [
        "SELECT COUNT(DISTINCT department) AS total_departments\r\n",
        "FROM silver_customer_products;"
      ]
    },
    {
      "name": "d8e7f5d5",
      "displayName": "Top Ten Aisle Purchase Volumes Summary",
      "queryLines": [
        "SELECT\r\n",
        "    department,\r\n",
        "    order_dow,\r\n",
        "    COUNT(*) AS total_orders\r\n",
        "FROM silver_customer_products\r\n",
        "GROUP BY department, order_dow;"
      ]
    }
  ],
